# Copy to .env in this folder (repo root: LeakSnipe/.env). Never commit .env.
# Restart LeakSnipe after editing (close app and run Launch-LeakSnipe.bat again).
#
# Install sidecar Python deps (from repo root — no uAgents needed for ASI:One HTTP API):
#   pip install -r sidecar\requirements.txt

# ── Recommended: ASI:One cloud (best coaching quality) ─────────────────────────
# Sign up / API key: https://asi1.ai
# Docs: https://docs.asi1.ai
#   OpenAI compatibility: https://docs.asi1.ai/documentation/build-with-asi-one/openai-compatibility
#   Models (asi1, asi1-ultra, asi1-mini): https://docs.asi1.ai/documentation/models
#   Chat API: https://docs.asi1.ai/api-reference/llm/chat-completion
#   Image API: https://docs.asi1.ai/api-reference/llm/image-generation
# Auth: Authorization: Bearer <key>  |  Base URL: https://api.asi1.ai/v1
ASI_ONE_API_KEY=your-asi1-api-key-here
# Optional second key — LeakSnipe splits hand analysis vs coach chat to avoid rate limits
ASI_ONE_API_KEY_FALLBACK=your-second-key-here
# ASI1_API_KEY=your-asi1-key-here          # alternate env name (also accepted)
# ASI1_BASE_URL=https://api.asi1.ai/v1     # override only if docs change endpoint
# ASI1_MODEL=asi1                          # default chat model: asi1 | asi1-ultra | asi1-mini
# ASI1_REQUEST_TIMEOUT=180                 # HTTP timeout seconds for ASI:One API calls

# ── Other cloud providers (optional) ───────────────────────────────────────────

# DeepSeek — https://platform.deepseek.com
DEEPSEEK_API_KEY=your-deepseek-key-here

# OpenAI
OPENAI_API_KEY=sk-your-openai-key-here

# Google Gemini — GEMINI_API_KEY or GOOGLE_API_KEY
GEMINI_API_KEY=your-gemini-key-here

# Anthropic Claude
ANTHROPIC_API_KEY=your-anthropic-key-here

# ── Local fallback: Ollama (no API key, slower/weaker for coaching) ───────────
# Install: https://ollama.com/download  then: ollama pull qwen2.5:7b
OLLAMA_BASE_URL=http://localhost:11434

# ── Remote DB proxy (sidecar /query endpoint, tunneled at db.leaksnipe.win) ───
# Required for the phone connector's tauri_db_* tools. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Give the same value to Cloudflare AI as the Bearer token the "leaksnipe"
# worker sends when it proxies tauri_db_* calls to db.leaksnipe.win/query.
LEAKSNIPE_DB_PROXY_KEY=your-long-random-shared-secret-here

# Database path (optional override)
# DH2_DB_PATH=D:\Users\admin\AppData\Roaming\DriveHUD 2\drivehud2.db

# Tesseract OCR path (Windows)
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
