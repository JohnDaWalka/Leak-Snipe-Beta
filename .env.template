# Poker Tracker Environment Variables
# Copy this file to .env and fill in your actual values
# DO NOT COMMIT .env to version control

# OpenAI API Key (for gpt-4o-mini chat, gpt-4o fallback)
OPENAI_API_KEY=your-openai-key-here

# Google Gemini API Key (alternative AI provider)
GEMINI_API_KEY=your-gemini-key-here

# Anthropic Claude API Key (fallback)
ANTHROPIC_API_KEY=your-anthropic-key-here

# Ollama Configuration (local AI)
OLLAMA_BASE_URL=http://localhost:11434

# Database path (optional override)
# DH2_DB_PATH=D:\Users\admin\AppData\Roaming\DriveHUD 2\drivehud2.db

# Tesseract OCR path (Windows)
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
